### tRPC — Health Check Query
# @name trpc-health
# @description Simple query procedure with no input. Verifies the server is reachable.
#
# Prerequisites:
#   A tRPC server must be running locally. To scaffold one quickly:
#     npx create-t3-app@latest --trpc --no-prisma --no-nextauth --no-tailwind
#   Then start with: npm run dev
#   Base URL: http://localhost:3000/api/trpc
#
# @protocol trpc

POST http://localhost:3000/api/trpc/health

### tRPC — Get User by ID
# @name trpc-get-user
# @description Query procedure with input — fetch a user by their ID.
# Assumes a `user.getById` procedure on the router.
# @protocol trpc

POST http://localhost:3000/api/trpc/user.getById

{"id": "1"}

### tRPC — List Users
# @name trpc-list-users
# @description Query that returns a list. Assumes `user.list` procedure.
# @protocol trpc

POST http://localhost:3000/api/trpc/user.list

{}

### tRPC — Create User (Mutation)
# @name trpc-create-user
# @description Mutation procedure — creates a user record.
# Assumes a `user.create` mutation.
# @protocol trpc

POST http://localhost:3000/api/trpc/user.create

{
  "name": "Protide E2E",
  "email": "e2e@protide.dev"
}

# @set created_user_id = $.result.data.id

### tRPC — Update User (Mutation)
# @name trpc-update-user
# @description Mutation that modifies an existing user.
# @depends trpc-create-user
# @protocol trpc

POST http://localhost:3000/api/trpc/user.update

{
  "id": "{{created_user_id}}",
  "name": "Protide E2E (Updated)"
}

### tRPC — Delete User (Mutation)
# @name trpc-delete-user
# @description Remove a user record.
# @depends trpc-create-user
# @protocol trpc

POST http://localhost:3000/api/trpc/user.delete

{"id": "{{created_user_id}}"}

### tRPC — Procedure with Auth Header
# @name trpc-authed
# @description Protected procedure — passes a JWT in the Authorization header.
# @protocol trpc

POST http://localhost:3000/api/trpc/post.getAll
Authorization: Bearer {{auth_token}}

{}

### tRPC — Environment Variable URL
# @name trpc-env-url
# @description Uses {{trpc_base}} environment variable for the server URL.
# Set trpc_base = http://localhost:3000/api/trpc in your environment.
# @protocol trpc

POST {{trpc_base}}/health

### tRPC — Custom Server Port
# @name trpc-custom-port
# @description Example for a tRPC server running on a non-default port.
# @protocol trpc

POST http://localhost:4000/trpc/post.list

{}
