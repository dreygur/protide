---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  align?: "left" | "center";
}

const { title, subtitle, label, align = "center" } = Astro.props;
const isCentered = align === "center";
---

<div data-animate class={`mb-16 ${isCentered ? "text-center" : ""}`}>
  {label && (
    <p class={`mb-3 text-xs font-medium uppercase tracking-widest text-[var(--color-accent)] ${isCentered ? "" : ""}`}>
      {label}
    </p>
  )}
  <h2 class="mb-4 text-3xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-4xl">
    {title}
  </h2>
  {subtitle && (
    <p class={`text-[var(--color-text-secondary)] leading-relaxed ${isCentered ? "mx-auto max-w-xl" : "max-w-lg"}`}>
      {subtitle}
    </p>
  )}
</div>
