---
// Mimics the Protide request panel: protocol tabs + URL bar + headers
---

<div class="overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-xs font-mono shadow-2xl">
  <!-- Window chrome -->
  <div class="flex items-center gap-1.5 border-b border-[var(--color-border)] bg-[var(--color-bg-primary)] px-4 py-3">
    <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
    <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
    <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
    <span class="ml-4 text-[var(--color-text-muted)]">protide — users.http</span>
  </div>

  <!-- Protocol tabs -->
  <div class="flex gap-0 border-b border-[var(--color-border)] bg-[var(--color-bg-primary)] overflow-x-auto">
    {[
      { label: "HTTP", active: true, color: "var(--color-method-get)" },
      { label: "GraphQL", color: "var(--color-proto-graphql)" },
      { label: "WebSocket", color: "var(--color-proto-ws)" },
      { label: "gRPC", color: "var(--color-proto-grpc)" },
      { label: "tRPC", color: "var(--color-proto-trpc)" },
    ].map((tab) => (
      <div
        class={`px-4 py-2.5 text-xs cursor-default whitespace-nowrap border-b-2 ${tab.active ? "border-current" : "border-transparent"}`}
        style={tab.active ? `color: ${tab.color}; border-color: ${tab.color}` : `color: var(--color-text-muted)`}
      >
        {tab.label}
      </div>
    ))}
  </div>

  <!-- URL bar -->
  <div class="flex items-center gap-2 border-b border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 py-2">
    <div class="flex items-center gap-1.5 rounded border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-2 py-1">
      <span style="color: var(--color-method-get)">GET</span>
      <span style="color: var(--color-text-muted)">▾</span>
    </div>
    <div class="flex-1 rounded border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-3 py-1 text-[var(--color-text-secondary)]">
      <span style="color: var(--color-text-muted)">https://</span>
      <span>api.example.com</span>
      <span style="color: var(--color-text-secondary)">/users/</span>
      <span style="color: var(--color-accent)">{"{{user_id}}"}</span>
    </div>
    <div class="rounded px-3 py-1 text-xs font-semibold" style="background: var(--color-accent); color: var(--color-bg-primary)">
      Send
    </div>
  </div>

  <!-- Tabs: Headers / Params / Body / Auth -->
  <div class="flex border-b border-[var(--color-border)] px-3">
    {["Headers", "Params", "Body", "Auth", "Scripts"].map((t, i) => (
      <div class={`px-3 py-2 text-xs cursor-default ${i === 0 ? "" : ""}`}
        style={i === 0 ? "color: var(--color-accent); border-bottom: 1px solid var(--color-accent)" : "color: var(--color-text-muted)"}>
        {t}
      </div>
    ))}
  </div>

  <!-- Header rows -->
  <div class="divide-y divide-[var(--color-border)] p-0">
    {[
      { enabled: true, key: "Authorization", value: "Bearer {{token}}" },
      { enabled: true, key: "Accept", value: "application/json" },
      { enabled: false, key: "X-Request-Id", value: "{{$uuid}}" },
    ].map((row) => (
      <div class="flex items-center gap-2 px-3 py-2">
        <div class={`h-3 w-3 rounded-sm border ${row.enabled ? "border-[var(--color-accent)] bg-[var(--color-accent)]" : "border-[var(--color-border)]"}`}></div>
        <span class={row.enabled ? "" : "opacity-40"} style="color: var(--color-method-post); min-width: 120px">{row.key}</span>
        <span class="opacity-50" style="color: var(--color-text-muted)">:</span>
        <span class={row.enabled ? "" : "opacity-40"} style={`color: ${row.value.includes("{{") ? "var(--color-accent)" : "var(--color-text-secondary)"}`}>
          {row.value}
        </span>
      </div>
    ))}
  </div>
</div>
