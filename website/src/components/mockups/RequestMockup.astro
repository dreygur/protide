---
// Mimics the Protide request panel: mode dropdown + URL bar + tabs + KV headers table
---

<div class="overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-xs font-mono shadow-2xl">

  <!-- URL bar: h=48px, bg_primary, px=12px, gap=8px — mode + method + url + send only -->
  <div class="flex h-12 items-center gap-2 border-b border-[var(--color-border)] bg-[var(--color-bg-primary)] px-3">
    <!-- Mode selector: w=88px h=28px bg_secondary, NO border-radius -->
    <div class="flex h-7 w-[88px] shrink-0 cursor-default items-center justify-between gap-1 border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-2">
      <span class="text-[12px] font-medium" style="color: var(--color-text-primary)">HTTP</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-muted)"><path d="m6 9 6 6 6-6"/></svg>
    </div>
    <!-- Method button: w=64px h=28px px=8px, method_color tinted, NO border-radius -->
    <div class="flex h-7 w-[64px] shrink-0 cursor-default items-center justify-center gap-1 border px-2 text-[11px] font-bold"
      style="color: var(--color-method-get); background: color-mix(in srgb, var(--color-method-get) 10%, transparent); border-color: color-mix(in srgb, var(--color-method-get) 20%, transparent)">
      GET
      <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.7"><path d="m6 9 6 6 6-6"/></svg>
    </div>
    <!-- URL input: flex-1 h=28px px=10px bg_tertiary, NO border-radius -->
    <div class="flex h-7 min-w-0 flex-1 items-center overflow-hidden border border-[var(--color-border)] px-2.5 text-[12px]" style="background: var(--color-bg-tertiary)">
      <span style="color: var(--color-text-muted)">https://</span><span style="color: var(--color-text-primary)">api.example.com/users</span>
    </div>
    <!-- Send button: h=28px px=12px, NO border-radius -->
    <div class="flex h-7 shrink-0 cursor-default items-center justify-center px-3 text-[12px] font-semibold" style="background: var(--color-accent); color: var(--color-bg-primary)">Send</div>
  </div>


  <!-- Tab bar: h=40px, bg_primary, border-b -->
  <div class="flex h-10 w-full items-center border-b border-[var(--color-border)] bg-[var(--color-bg-primary)]">
    {[
      { label: "Params",   active: false, count: 0 },
      { label: "Headers",  active: true,  count: 2 },
      { label: "Body",     active: false, count: 0 },
      { label: "Auth",     active: false, count: 0 },
      { label: "Scripts",  active: false, count: 0 },
      { label: "Data",     active: false, count: 0 },
      { label: "Settings", active: false, count: 0 },
    ].map((tab) => (
      <div class="flex h-full cursor-default items-center gap-1.5 border-b-2 px-3"
        style={tab.active
          ? "color: var(--color-text-primary); border-color: var(--color-accent); font-weight: 500"
          : "color: var(--color-text-secondary); border-color: transparent"}>
        <span class="text-[12px]">{tab.label}</span>
        {tab.count > 0 && (
          <span class="px-[5px] py-px text-[10px] font-medium"
            style="background: color-mix(in srgb, var(--color-accent) 15%, transparent); color: var(--color-accent)">
            {tab.count}
          </span>
        )}
      </div>
    ))}
  </div>

  <!-- KV table header: drag-placeholder(12px) + checkbox-placeholder(16px) + HEADER(150px) + col-drag(1px) + VALUE + count-badge + remove-placeholder(28px) -->
  <div class="mb-1 flex w-full items-center gap-2 border-b border-[var(--color-border)] px-0.5 py-1.5">
    <div class="w-3 shrink-0"></div>
    <div class="h-4 w-4 shrink-0"></div>
    <div class="w-[150px] shrink-0 text-[10px] font-semibold" style="color: color-mix(in srgb, var(--color-accent) 70%, transparent)">HEADER</div>
    <div class="w-px self-stretch" style="background: color-mix(in srgb, var(--color-border) 60%, transparent)"></div>
    <div class="flex flex-1 items-center justify-between">
      <span class="text-[10px] font-semibold" style="color: var(--color-text-secondary)">VALUE</span>
      <!-- count badge: px=6px py=2px accent tinted, NO border-radius -->
      <span class="border px-[6px] py-0.5 text-[10px] font-medium"
        style="background: color-mix(in srgb, var(--color-accent) 12%, transparent); border-color: color-mix(in srgb, var(--color-accent) 35%, transparent); color: var(--color-accent)">
        2 active
      </span>
    </div>
    <div class="h-7 w-7 shrink-0"></div>
  </div>

  <!-- Header rows: drag(12x28) + checkbox(16px) + key-input(150px h=28px bg_tertiary) + col-divider(4px) + value-input(flex-1 h=28px bg_tertiary) + remove(28px) -->
  <div class="flex flex-col gap-0.5 pb-2">
    {[
      { enabled: true,  key: "Authorization", value: "Bearer {{token}}" },
      { enabled: true,  key: "Accept",        value: "application/json" },
      { enabled: false, key: "X-Request-Id",  value: "{{$uuid}}" },
    ].map((row) => (
      <div class="flex items-center gap-2 px-0.5 py-1" style={!row.enabled ? "opacity: 0.4" : ""}>
        <!-- drag handle -->
        <div class="flex h-7 w-3 shrink-0 items-center justify-center" style="color: var(--color-text-muted); opacity: 0.3; font-size: 8px; letter-spacing: -1px">⠿</div>
        <!-- checkbox: 16px, NO border-radius -->
        <div class={`flex h-4 w-4 shrink-0 items-center justify-center border ${row.enabled ? "border-[var(--color-accent)]" : "border-[var(--color-border)]"}`}
          style={row.enabled ? "background: var(--color-accent)" : ""}>
          {row.enabled && (
            <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-bg-primary)"><path d="M20 6 9 17l-5-5"/></svg>
          )}
        </div>
        <!-- key input: w=150px h=28px px=8px bg_tertiary text=12px, NO border-radius -->
        <div class="flex h-7 w-[150px] shrink-0 items-center overflow-hidden border border-transparent px-2 text-[12px]" style="background: var(--color-bg-tertiary); color: var(--color-text-primary)">{row.key}</div>
        <!-- col divider -->
        <div class="w-1 self-stretch" style="background: color-mix(in srgb, var(--color-border) 60%, transparent)"></div>
        <!-- value input: flex-1 h=28px px=8px bg_tertiary text=12px, NO border-radius -->
        <div class="flex h-7 flex-1 items-center overflow-hidden border border-transparent px-2 text-[12px]" style="background: var(--color-bg-tertiary); color: var(--color-text-primary)">{row.value}</div>
        <!-- remove btn: 28px -->
        <div class="flex h-7 w-7 shrink-0 items-center justify-center text-[14px]" style="color: var(--color-text-muted)">×</div>
      </div>
    ))}
  </div>
</div>
