---
// Mimics the actual Protide mock server panel: header + status bar + route cards. NO border-radius on interactive elements.
---

<div class="overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-primary)] text-xs font-mono shadow-2xl">

  <!-- Panel header: "Mock Server" label + Stop button (status_client_error = #fb923c orange, NO border-radius) -->
  <div class="flex items-center justify-between border-b border-[var(--color-border)] px-3 py-2">
    <span class="text-sm" style="color: var(--color-text-primary)">Mock Server</span>
    <div class="cursor-default border px-3 py-1 text-sm"
      style="border-color: color-mix(in srgb, var(--color-status-4xx) 50%, transparent); background: color-mix(in srgb, var(--color-status-4xx) 10%, transparent); color: var(--color-status-4xx)">
      Stop
    </div>
  </div>

  <!-- Status bar: 8px square dot (no border-radius) + url, bg_secondary -->
  <div class="border-b border-[var(--color-border)] px-3 py-2" style="background: var(--color-bg-secondary)">
    <div class="flex items-center gap-2">
      <div class="h-2 w-2" style="background: var(--color-status-2xx)"></div>
      <span class="text-xs" style="color: var(--color-text-secondary)">http://localhost:3001</span>
    </div>
  </div>

  <!-- Route cards: flex-col gap-2 p-3, each card bg_secondary border, NO border-radius -->
  <div class="flex flex-col gap-2 p-3">
    {[
      { method: "GET",    path: "/api/users",      status: 200, color: "var(--color-method-get)" },
      { method: "POST",   path: "/api/auth/login", status: 201, color: "var(--color-method-post)" },
      { method: "GET",    path: "/api/users/:id",  status: 200, color: "var(--color-method-get)" },
      { method: "PUT",    path: "/api/users/:id",  status: 200, color: "var(--color-method-put)" },
      { method: "DELETE", path: "/api/users/:id",  status: 204, color: "var(--color-method-delete)" },
    ].map((route) => (
      <div class="flex items-center justify-between border px-2 py-1" style="background: var(--color-bg-secondary); border-color: var(--color-border)">
        <div class="flex items-center gap-2">
          <span class="text-xs font-bold" style={`color: ${route.color}`}>{route.method}</span>
          <span class="text-sm" style="color: var(--color-text-primary)">{route.path}</span>
        </div>
        <div class="flex items-center gap-2">
          <!-- status pill: px=8px py=1px, NO border-radius -->
          <div class="px-2 py-px text-xs" style={`background: ${route.status < 300 ? "var(--color-status-2xx)" : route.status < 400 ? "var(--color-status-3xx)" : "var(--color-status-4xx)"}; color: var(--color-bg-primary)`}>
            {route.status}
          </div>
          <span class="cursor-default text-xs" style="color: var(--color-status-4xx)">x</span>
        </div>
      </div>
    ))}
  </div>

  <!-- Record mode footer -->
  <div class="border-t border-[var(--color-border)] px-3 py-2" style="background: var(--color-bg-secondary)">
    <div class="flex items-center gap-2">
      <span class="h-1.5 w-1.5 rounded-full animate-pulse" style="background: var(--color-accent)"></span>
      <span style="color: var(--color-text-muted)">Record mode active - proxying to https://api.example.com</span>
    </div>
  </div>
</div>
