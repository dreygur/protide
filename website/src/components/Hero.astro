---
import Button from "./shared/Button.astro";

const base = import.meta.env.BASE_URL;
---

<section class="relative overflow-hidden px-6 py-24 text-center">
  <!-- Dot grid background -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(var(--color-text-muted) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <!-- Radial glow -->
  <div
    class="pointer-events-none absolute left-1/2 top-0 h-[500px] w-[700px] -translate-x-1/2 rounded-full blur-3xl"
    style="background: radial-gradient(ellipse, color-mix(in srgb, var(--color-accent) 8%, transparent) 0%, transparent 70%);"
  ></div>

  <div class="relative mx-auto max-w-5xl">
    <!-- Badge -->
    <div class="mb-8 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs"
      style="border-color: var(--color-border); background: var(--color-bg-elevated); color: var(--color-text-secondary)">
      <span class="h-1.5 w-1.5 rounded-full" style="background: var(--color-accent)"></span>
      Built with Rust &amp; GPUI &nbsp;·&nbsp; MIT License &nbsp;·&nbsp; v0.1.0-alpha.3 &nbsp;·&nbsp;
      <span class="font-semibold" style="color: var(--color-method-put)">alpha</span>
    </div>

    <h1 class="mb-6 text-5xl font-bold leading-tight tracking-tight sm:text-6xl lg:text-7xl"
      style="color: var(--color-text-primary)">
      API Testing,<br />
      <span style="color: var(--color-accent)">Natively Fast</span>
    </h1>

    <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed" style="color: var(--color-text-secondary)">
      A GPU-accelerated desktop API client built with Rust. HTTP, GraphQL, WebSocket,
      gRPC, tRPC, and Socket.IO - all from a single
      <code class="px-1.5 py-0.5 text-base" style="background: var(--color-bg-elevated); color: var(--color-accent)">.http</code>
      file.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <Button href="https://github.com/dreygur/protide/releases/latest" variant="primary" external>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        Download
      </Button>
      <Button href="https://github.com/dreygur/protide" variant="outline" external>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        View on GitHub
      </Button>
    </div>

    <!-- Screenshot -->
    <div class="mt-16 overflow-hidden border shadow-2xl" style="border-color: var(--color-border)">
      <img
        src={`${base}/screenshot.png`}
        alt="Protide - API testing tool screenshot"
        class="w-full"
        loading="eager"
      />
    </div>
  </div>
</section>
