---
import SectionHeader from "./shared/SectionHeader.astro";
import CollabMockup from "./mockups/CollabMockup.astro";

const items = [
  {
    icon: '<rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>',
    title: "Code-based pairing",
    desc: "Every session gets a unique code. Share it with a teammate and connect in seconds.",
    color: "var(--color-accent)",
  },
  {
    icon: '<path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/><path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/><path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/><path d="m2 2 20 20"/>',
    title: "PAKE secure pairing",
    desc: "Password-authenticated key exchange - encrypted from first contact, no certificates needed.",
    color: "var(--color-proto-grpc)",
  },
  {
    icon: '<path d="M14 4a2 2 0 0 1 2-2"/><path d="M16 10a2 2 0 0 1-2-2"/><path d="M20 2a2 2 0 0 1 2 2"/><path d="M22 8a2 2 0 0 1-2 2"/><path d="m3 7 3 3 3-3"/><path d="M6 10V5a3 3 0 0 1 3-3h1"/><rect x="2" y="14" width="8" height="8" rx="2"/>',
    title: "CRDT-based sync",
    desc: "LWW registers with Lamport timestamps. Changes always converge, no merge conflicts.",
    color: "var(--color-method-put)",
  },
  {
    icon: '<line x1="22" x2="2" y1="12" y2="12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/><line x1="6" x2="6.01" y1="16" y2="16"/><line x1="10" x2="10.01" y1="16" y2="16"/>',
    title: "BYOB remote sync",
    desc: "Use Dropbox, Google Drive, or a GitHub repo as the sync backend for distributed teams.",
    color: "var(--color-method-post)",
  },
];
---

<section class="px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
      <div data-animate style="--anim-delay: 0ms">
        <CollabMockup />
      </div>

      <div data-animate style="--anim-delay: 150ms">
        <SectionHeader
          title="Team sync without a server"
          subtitle="Share a pairing code, connect instantly. No accounts, no cloud, no internet required."
          align="left"
          label="Local-First Collaboration"
        />

        <div class="flex flex-col gap-4 mb-8">
          {items.map((item) => (
            <div class="flex items-start gap-3 border p-4" style="border-color: var(--color-border); background: var(--color-bg-secondary)">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" style={`color: ${item.color}`} set:html={item.icon} />
              <div>
                <div class="mb-1 font-semibold text-sm" style="color: var(--color-text-primary)">{item.title}</div>
                <div class="text-sm leading-relaxed" style="color: var(--color-text-secondary)">{item.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
