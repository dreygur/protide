---
import Button from "./shared/Button.astro";
---

<section class="relative overflow-hidden px-6 py-24 text-center">
  <!-- Glow -->
  <div
    class="pointer-events-none absolute left-1/2 bottom-0 h-[300px] w-[500px] -translate-x-1/2 rounded-full blur-3xl"
    style="background: radial-gradient(ellipse, color-mix(in srgb, var(--color-accent) 6%, transparent) 0%, transparent 70%);"
  ></div>

  <div class="relative mx-auto max-w-3xl">
    <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl" style="color: var(--color-text-primary)">
      Ready to ditch Postman?
    </h2>
    <p class="mx-auto mb-10 max-w-xl text-lg leading-relaxed" style="color: var(--color-text-secondary)">
      Native performance. File-based collections. No account required. Free and open source forever.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4 mb-12">
      <Button href="https://github.com/dreygur/protide/releases/latest" variant="primary" external>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download latest release
      </Button>
      <Button href="https://github.com/dreygur/protide" variant="outline" external>
        View source on GitHub
      </Button>
    </div>

    <!-- Cargo install -->
    <div class="inline-block rounded-xl border p-6 text-left font-mono text-sm" style="border-color: var(--color-border); background: var(--color-bg-secondary)">
      <div class="mb-2 text-xs" style="color: var(--color-text-muted)">Or install the LSP server via cargo:</div>
      <div class="flex items-center gap-3">
        <span style="color: var(--color-text-muted)">$</span>
        <span>
          <span style="color: var(--color-method-post)">cargo install</span>
          <span style="color: var(--color-text-secondary)"> --git </span>
          <span style="color: var(--color-method-put)">https://github.com/dreygur/protide</span>
          <span style="color: var(--color-text-secondary)"> protide-lsp</span>
        </span>
      </div>
    </div>
  </div>
</section>
